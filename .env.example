# API base URL used by the browser application.
# Use /api/ when the frontend is served behind the same reverse proxy as the API.
VITE_IDELIUM_API_BASE_URL=/api/

# Public product or documentation URL shown by informational views.
VITE_IDELIUM_PUBLIC_SITE_URL=https://github.com/idelium

# Public reCAPTCHA site key.
VITE_GOOGLE_SITE_KEY=

# Public Google tag identifier.
VITE_GOOGLE_TAG_ID=
