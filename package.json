{
  "name": "idelium-web-vue3.7.1",
  "version": "0.8.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:dependencies": "npm audit --audit-level=high",
    "lint": "eslint . --fix",
    "lint:check": "eslint . --max-warnings=0",
    "format": "prettier --write src/services src/stores src/domain src/router src/view/pages/login.vue src/view/testperformed tests vite.config.js vitest.config.js eslint.config.js",
    "format:check": "prettier --check src/services src/stores src/domain src/router src/view/pages/login.vue src/view/testperformed tests vite.config.js vitest.config.js eslint.config.js"
  },
  "dependencies": {
