    "@fortawesome/vue-fontawesome": "^3.0.4",
    "@vue/compiler-sfc": "^3.5.14",
    "@vue/devtools-api": "^8.1.5",
    "axios": "^1.6.0",
    "bootstrap": "^5.3.8",
    "copy-to-clipboard": "^3.3.3",
    "element-plus": "^2.5.4",
    "jsoneditor": "^9.10.2",
    "konva": "^10.3.0",
    "mitt": "^3.0.1",
    "pinia": "^4.0.2",
    "splitpanes": "^3.2.0",
    "vue": "^3.5.14",
    "vue-country-flag-next": "^2.3.2",
