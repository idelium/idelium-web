    "@eslint/object-schema": "^2.1.6",
    "@rushstack/eslint-patch": "^1.3.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.7",
    "@vue/eslint-config-prettier": "^10.2.0",
